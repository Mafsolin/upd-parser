# Copy this file to .env and fill in real values.

# Добавьте провайдера, URL, модель и API-ключ в окне «Настройки» приложения.
# Пользовательские профили хранятся в файле upd_provider_profiles.json.

# Язык интерфейса: ru или en. Проверка обновлений при запуске: true или false.
UPD_LANGUAGE=ru
UPD_AUTO_UPDATE_CHECK=true

# Telegram bot token from @BotFather (required only for bot.py)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
